{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-frontend.sh",
            "timeout": 30,
            "statusMessage": "Formatting frontend file..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-backend.sh",
            "timeout": 30,
            "statusMessage": "Formatting Python file..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-python.sh",
            "timeout": 30,
            "statusMessage": "Linting Python file..."
          }
        ]
      }
    ]
  }
}

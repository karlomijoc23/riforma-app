# Riforma Frontend — Production Environment
# CRA auto-loads this file during `craco build`.

# Backend API URL — leave empty for same-origin (Apache proxies /api/)
REACT_APP_BACKEND_URL=

# Default tenant
REACT_APP_DEFAULT_TENANT_ID=tenant-default

# Sentry (uncomment to enable)
# REACT_APP_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

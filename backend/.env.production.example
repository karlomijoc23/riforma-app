# ============================================================
# Riforma Backend — Production Environment Variables
# ============================================================
# Copy to /opt/riforma/.env (or backend/.env) and fill in values.
# Lines starting with # are comments; uncomment to enable.
# ============================================================

# ─── Core ────────────────────────────────────────────────────
ENVIRONMENT=production

# ─── Database ────────────────────────────────────────────────
# Option A: Full connection URL (takes precedence)
DATABASE_URL=mariadb+asyncmy://riforma:YOUR_DB_PASSWORD@localhost:3306/riforma

# Option B: Individual components (used if DATABASE_URL is unset)
# DB_ENGINE=mariadb+asyncmy
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=riforma
# DB_PASSWORD=YOUR_DB_PASSWORD
# DB_NAME=riforma

# Pool tuning
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_ECHO=false

# ─── Auth ────────────────────────────────────────────────────
# REQUIRED — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
AUTH_SECRET=

# ─── Admin Seeding ───────────────────────────────────────────
# Set to true ONLY on first deploy, then set back to false
SEED_ADMIN_ON_STARTUP=false
# INITIAL_ADMIN_EMAIL=admin@example.com
# INITIAL_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY
# INITIAL_ADMIN_FULL_NAME=Portfolio Admin
# INITIAL_ADMIN_ROLE=owner

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (NO trailing slash)
BACKEND_CORS_ORIGINS=https://your-domain.com

# ─── Logging ─────────────────────────────────────────────────
LOG_FORMAT=json
LOG_LEVEL=INFO

# ─── Sentry (error tracking) ────────────────────────────────
# SENTRY_DSN_BACKEND=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── AI ──────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── SMTP / Email Notifications ─────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@your-domain.com
# SMTP_PASSWORD=YOUR_SMTP_PASSWORD
# SMTP_FROM=notifications@your-domain.com

# ─── Paths ───────────────────────────────────────────────────
# UPLOAD_DIR=/opt/riforma/uploads

# ─── Tenant Defaults ────────────────────────────────────────
# DEFAULT_TENANT_ID=tenant-default
# DEFAULT_TENANT_NAME=Glavna portfelj
